#include <iostream>
using namespace std;

int main() {
    double kecepatan, waktu, jarak;

    cout << "Masukkan kecepatan (km/jam): ";
    cin >> kecepatan;
    cout << "Masukkan waktu (jam): ";
    cin >> waktu;

    // Rumus: s = v * t
    jarak = kecepatan * waktu;

    cout << "Jarak yang ditempuh: " << jarak << " km" << endl;

    return 0;
}

